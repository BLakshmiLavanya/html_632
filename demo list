<!DOCTYPE html>
<html>
<head>
    <title>HTML Lists Example</title>
</head>
<body>

<h1>HTML Lists Demonstration</h1>

<h2>Ordered List</h2>
<ol>
    <li>Step One</li>
    <li>Step Two</li>
    <li>Step Three</li>
</ol>

<h2>Unordered List</h2>
<ul>
    <li>Apple</li>
    <li>Banana</li>
    <li>Mango</li>
</ul>

<h2>Nested List</h2>
<ul>
    <li>Fruits
        <ul>
            <li>Apple</li>
            <li>Orange</li>
        </ul>
    </li>
    <li>Vegetables
        <ul>
            <li>Carrot</li>
            <li>Potato</li>
        </ul>
    </li>
</ul>

<h2>Ordered List inside Unordered List</h2>
<ul>
    <li>Steps to Prepare Coffee
        <ol>
            <li>Boil water</li>
            <li>Add coffee powder</li>
            <li>Add sugar</li>
            <li>Stir well</li>
        </ol>
    </li>
</ul>

<h2>Definition List</h2>
<dl>
    <dt>HTML</dt>
    <dd>HyperText Markup Language</dd>

    <dt>CSS</dt>
    <dd>Cascading Style Sheets</dd>

    <dt>JavaScript</dt>
    <dd>Programming language for web pages</dd>
</dl>

</body>
</html>